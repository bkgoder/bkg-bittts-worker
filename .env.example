# Koordinator (öffentlich)
BITTTS_COORDINATOR_URL=https://train.eysho.info

# Worker-Token aus https://train.eysho.info/ui (Tokens-Tab)
BITTTS_WORKER_TOKEN=

# Anzeigename im Dashboard
BITTTS_WORKER_NAME=worker1

# Trainingsskripte aus bkg-bittts-shutup
# Windows: C:\Users\YOU\src\bkg-bittts-shutup
# WSL:     /home/you/bkg-bittts-shutup
BITTTS_SHUTUP_ROOT=

# MLS-Cache (leer = ./data/mls-german)
BITTTS_WORKER_DATASET=mls-german
BITTTS_DATASET_PROFILE=mls-german
BITTTS_WORKER_POLL_SECONDS=5

# Optional
HF_TOKEN=
