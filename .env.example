# Coordinator
BITTTS_COORDINATOR_URL=https://train.eysho.info

# Worker-Token aus https://train.eysho.info/ui/
BITTTS_WORKER_TOKEN=

BITTTS_WORKER_NAME=worker1
BITTTS_WORKER_DATASET=data/mls-german
BITTTS_DATASET_PROFILE=mls-german
BITTTS_DATASET_SPLIT=9_hours
BITTTS_MAX_HOURS=9.0
BITTTS_WORKER_POLL_SECONDS=5

# Das Trainings-Bundle wird nur beim ersten Start geladen.
# Ein vorhandenes Bundle wird NICHT heimlich ersetzt.
BITTTS_BUNDLE_FORCE=0

# Optional: lokales bkg-bittts-shutup-Repo statt Trainings-Bundle.
# BITTTS_SHUTUP_ROOT=/pfad/zu/bkg-bittts-shutup

# Optional: get_job.sh darf nur bei sauberem Git-Stand automatisch pullen.
BITTTS_AUTO_PULL=0

# Docker GPU
# NVIDIA_VISIBLE_DEVICES=all

# Optional
HF_TOKEN=
