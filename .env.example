# Koordinator — Trainingsskripte (inkl. scipy/monotonic_align-Patches) per Bootstrap
BITTTS_COORDINATOR_URL=https://train.eysho.info

# Worker-Token aus https://train.eysho.info/ui
BITTTS_WORKER_TOKEN=

BITTTS_WORKER_NAME=worker1
BITTTS_WORKER_DATASET=mls-german
BITTTS_DATASET_PROFILE=mls-german
BITTTS_DATASET_SPLIT=9_hours
BITTTS_MAX_HOURS=9.0
BITTTS_WORKER_POLL_SECONDS=5

# Bundle neu laden nach Koordinator-Update (oder runtime/bundle löschen)
# BITTTS_BUNDLE_FORCE=1

# Optional: lokales shutup-Repo statt Remote-Bundle (nur Entwicklung)
# BITTTS_SHUTUP_ROOT=/shutup
# In compose.yaml Volume einkommentieren: ../bkg-bittts-shutup:/shutup:ro

# Docker GPU (compose.yaml)
# NVIDIA_VISIBLE_DEVICES=all

# Optional
HF_TOKEN=
